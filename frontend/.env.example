# Frontend env vars — copy to .env.local and fill in values
# NEXT_PUBLIC_* vars are exposed to the browser

# Supabase connection
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Revalidation secret (must match ETL NEXT_REVALIDATE_SECRET)
NEXT_REVALIDATE_SECRET=your-revalidation-secret

# Optional: Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
