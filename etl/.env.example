# ===========================================================================
# AutoQuant ETL — Environment Variables
# Copy to .env and fill in real values. Never commit .env!
# ===========================================================================

# ---------------------------------------------------------------------------
# Database (Supabase or Neon PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---------------------------------------------------------------------------
# Telegram Alerts
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ---------------------------------------------------------------------------
# VAHAN Connector
# ---------------------------------------------------------------------------
# Optional: override default VAHAN URL if mirror changes
# VAHAN_BASE_URL=https://vahan.parivahan.gov.in/vahan4dashboard/

# ---------------------------------------------------------------------------
# ETL Behaviour
# ---------------------------------------------------------------------------
# Set to 'true' to skip actual DB writes (for testing)
DRY_RUN=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Playwright headless mode (true in production, false for local debugging)
PLAYWRIGHT_HEADLESS=true
